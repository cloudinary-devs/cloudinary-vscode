{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Cloudinary agent skills installation config. Single source of truth consumed by VS Code extension, React starter kit CLI, and other CLIs.",

  "canonical": {
    "project": ".agents/skills",
    "global": "~/.agents/skills"
  },

  "scopes": {
    "project": {
      "description": "Installed in the current project directory, committed to version control",
      "basePath": "."
    },
    "global": {
      "description": "Installed in the user's home directory, available across all projects",
      "basePath": "~"
    }
  },

  "platforms": [
    {
      "id": "amp",
      "name": "Amp",
      "skillsDir": ".agents/skills",
      "globalSkillsDir": "~/.agents/skills",
      "isUniversal": true
    },
    {
      "id": "claude-code",
      "name": "Claude Code",
      "skillsDir": ".claude/skills",
      "globalSkillsDir": "~/.claude/skills",
